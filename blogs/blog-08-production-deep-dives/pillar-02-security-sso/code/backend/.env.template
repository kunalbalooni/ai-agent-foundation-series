# Azure AD / Entra ID — Backend API (backend app registration)
# See Steps 1–3 in blog.md for how to obtain these values.
AZURE_AD_TENANT_ID=<your-tenant-id>
AZURE_AD_CLIENT_ID=<backend-api-client-id>

# Group IDs for RBAC (Entra ID security group object IDs)
# Leave blank to disable group-based access control.
GROUP_ID_AGENT_USERS=
GROUP_ID_AGENT_ADMINS=

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
